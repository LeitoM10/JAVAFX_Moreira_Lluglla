<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      alignment="CENTER"
      spacing="12"
      style="-fx-background-color: linear-gradient(to bottom, #1f2937, #111827);"
      prefWidth="360">

    <Label text="CAJERO - REGISTRO DE COMPRA"
           style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>

    <VBox spacing="8"
          alignment="CENTER"
          style="-fx-background-color: #1f2937; -fx-padding: 15; -fx-background-radius: 12;">

        <TextField fx:id="txtNombre" promptText="Nombre"/>
        <TextField fx:id="txtCedula" promptText="Cédula"/>
        <TextField fx:id="txtProducto" promptText="Producto"/>
        <TextField fx:id="txtPrecio" promptText="Precio"/>
        <TextField fx:id="txtCompra" promptText="Número de compra"/>

        <Button text="Registrar"
                style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-background-radius: 8;"/>

        <Label fx:id="lblMensaje"
               style="-fx-text-fill: #facc15;"/>

    </VBox>

</VBox>
